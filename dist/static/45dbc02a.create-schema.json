                          }
                        ],
                        "level": "warning",
                        "message": "Title should be concise"
                      }
                    ],
                    "description": "The title that appears in the accordion header",
                    "name": "title",
                    "type": "string",
                    "title": "Accordion Title"
                  },
                  {
                    "options": {
                      "hotspot": true
                    },
                    "description": "Icon displayed next to the title in the accordion header",
                    "fields": [
                      {
