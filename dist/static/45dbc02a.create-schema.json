  {
    "fields": [
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              },
              {
                "flag": "max",
                "constraint": 100
              }
            ],
            "level": "error"
          }
        ],
        "description": "Name of the person giving the review",
        "name": "name",
        "type": "string"
      },
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "description": "Email address of the reviewer",
        "name": "email",
        "type": "string"
      },
      {
        "description": "Company or organization name (optional)",
        "name": "company",
        "type": "string",
        "title": "Company/Organization"
      },
      {
        "options": {
          "list": [
            {
              "title": "1 Star",
              "value": 1
            },
            {
              "title": "2 Stars",
              "value": 2
            },
            {
              "title": "3 Stars",
              "value": 3
            },
            {
              "title": "4 Stars",
              "value": 4
            },
            {
              "title": "5 Stars",
              "value": 5
            }
          ],
          "layout": "radio"
        },
        "validation": [
          {
            "rules": [
              {
                "flag": "valid",
                "constraint": [
                  1,
                  2,
                  3,
                  4,
                  5
                ]
              },
              {
                "flag": "presence",
                "constraint": "required"
              },
              {
                "flag": "min",
                "constraint": 1
              },
              {
                "flag": "max",
                "constraint": 5
              }
            ],
            "level": "error",
            "message": "Rating must be between 1 and 5"
          }
        ],
        "description": "Rating out of 5",
        "name": "rating",
        "type": "number"
      },
      {
        "rows": 5,
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              },
              {
                "flag": "min",
                "constraint": 10
              },
              {
                "flag": "max",
                "constraint": 1000
              }
            ],
            "level": "error"
          }
        ],
        "description": "The review content",
        "name": "review",
        "type": "text",
        "title": "Review Text"
      },
      {
        "options": {
          "list": [
            {
              "title": "Pending",
              "value": "pending"
            },
            {
              "title": "Published",
              "value": "published"
            },
            {
              "title": "Rejected",
              "value": "rejected"
            }
          ],
          "layout": "radio"
        },
        "initialValue": "pending",
        "validation": [
          {
            "rules": [
              {
                "flag": "valid",
                "constraint": [
                  "pending",
                  "published",
                  "rejected"
                ]
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "description": "Review status - Pending reviews need approval",
        "name": "status",
        "type": "string"
      },
      {
        "description": "When the review was submitted",
        "readOnly": true,
        "name": "submittedAt",
        "type": "datetime"
      },
      {
        "options": {
          "hotspot": true
        },
        "description": "Profile picture of the reviewer (optional)",
